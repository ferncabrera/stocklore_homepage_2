---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/sections/PageHero.astro";
import Card from "../components/ui/Card.astro";
import { SITE } from "../data/site";
---

<BaseLayout
  title="Contact · Stocklore"
  description="Questions, bug reports, partnership or investment inquiries — reach the Stocklore team at support@stocklore.app. A human answers."
>
  <PageHero kicker="Contact" title="Talk to a human" lede="Bugs, questions, ideas, business — one inbox, real answers." />

  <div class="safe-x">
    <div class="mx-auto w-full max-w-3xl space-y-6 py-16">
      <Card>
        <h2 class="font-heading text-xl font-bold">Support &amp; general inquiries</h2>
        <p class="mt-3 text-muted-foreground">
          For bugs, questions about the app, or anything else about the project, email
          <a href={`mailto:${SITE.supportEmail}`} class="font-medium text-brand hover:underline">{SITE.supportEmail}</a>. Beta feedback is read by the people
          who build the product — if something's broken or missing, telling us genuinely changes the <a
            href="/roadmap"
            class="font-medium text-brand hover:underline">roadmap</a
          >.
        </p>
      </Card>

      <Card>
        <h2 class="font-heading text-xl font-bold">Partners &amp; investors</h2>
        <p class="mt-3 text-muted-foreground">
          We're open to conversations with partners and investors who care about Canadian small business. Reach out at
          <a href={`mailto:${SITE.supportEmail}`} class="font-medium text-brand hover:underline">{SITE.supportEmail}</a>
          and we'll reply as soon as possible.
        </p>
      </Card>

      <Card>
        <h2 class="font-heading text-xl font-bold">Careers</h2>
        <p class="mt-3 text-muted-foreground">
          We're not advertising any positions right now, but there may be opportunities for the right person — introduce yourself and tell us what you'd want to
          build.
        </p>
      </Card>

      <p class="text-sm text-muted-foreground">
        Prefer a slower drip? <a href="/email" class="font-medium text-brand hover:underline">Join the email list</a>
        and get updates as we ship.
      </p>
    </div>
  </div>
</BaseLayout>

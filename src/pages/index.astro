---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/sections/Hero.astro";
import BenefitStrip from "../components/sections/BenefitStrip.astro";
import ProductTour from "../components/sections/ProductTour.astro";
import WedgeSpotlight from "../components/sections/WedgeSpotlight.astro";
import UseCases from "../components/sections/UseCases.astro";
import WhyStocklore from "../components/sections/WhyStocklore.astro";
import BuildingInTheOpen from "../components/sections/BuildingInTheOpen.astro";
import Faq from "../components/sections/Faq.astro";
import CtaBand from "../components/sections/CtaBand.astro";
import { SITE } from "../data/site";
import { faqJsonLd } from "../data/faq";

const softwareApplicationJsonLd = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: SITE.name,
  applicationCategory: "BusinessApplication",
  operatingSystem: "Web",
  url: SITE.portalUrl,
  description: SITE.description,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "CAD",
    description: "Free during open beta",
  },
};
---

<BaseLayout
  title="Stocklore — Inventory & Manufacturing Software for Canadian Small Business"
  description={SITE.description}
  jsonLd={[softwareApplicationJsonLd, faqJsonLd()]}
>
  <Hero />
  <BenefitStrip />
  <ProductTour />
  <WedgeSpotlight />
  <UseCases />
  <WhyStocklore />
  <BuildingInTheOpen />
  <Faq />
  <CtaBand />
</BaseLayout>

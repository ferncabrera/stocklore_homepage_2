---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/sections/PageHero.astro";
import Card from "../components/ui/Card.astro";
import EmailCapture from "../components/sections/EmailCapture.astro";
---

<BaseLayout
  title="Get Updates · Stocklore"
  description="Join the Stocklore email list and get product updates as we ship new features — no spam, just what's new."
>
  <PageHero
    kicker="Email list"
    title="Get updates as we ship"
    lede="We build in the open and ship often. Leave your email and we'll tell you when something new lands — no spam, easy to leave."
  />

  <div class="safe-x">
    <div class="mx-auto w-full max-w-xl py-16">
      <Card class="p-8">
        <EmailCapture />
      </Card>
      <p class="mt-6 text-center text-sm text-muted-foreground">
        Curious what "shipping often" looks like? See the
        <a href="/roadmap" class="font-medium text-brand hover:underline">roadmap</a>.
      </p>
    </div>
  </div>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/sections/PageHero.astro";
import CtaBand from "../components/sections/CtaBand.astro";
import AiVisionCard from "../components/sections/AiVisionCard.astro";
import Badge from "../components/ui/Badge.astro";
import Card from "../components/ui/Card.astro";
import { shippedByMonth, inProgress, planned, vision, formatMonth } from "../data/roadmap";

const months = shippedByMonth();
const visionCards = vision.filter((i) => i.id !== "ai-assistant");
---

<BaseLayout
  title="Roadmap — Building in the Open · Stocklore"
  description="What we've shipped, what we're building now, and where Stocklore is headed — including our human-in-the-loop AI assistant. Updated as we ship."
>
  <PageHero
    kicker="Building in the open"
    title="Small team. Big shipping cadence."
    lede="We publish what we ship and what's next, and heavy end-to-end testing lets us move fast without breaking your data. This page is the honest ledger of that work."
  />

  <div class="safe-x">
    <div class="mx-auto w-full max-w-4xl py-16">
      <!-- Shipped timeline -->
      <section aria-labelledby="shipped-title">
        <h2 id="shipped-title" class="flex items-center gap-3 font-heading text-2xl font-bold">
          Shipped
          <Badge status="live" />
        </h2>

        <div class="mt-8 space-y-12">
          {
            months.map(([month, items]) => (
              <section aria-label={formatMonth(month)} class="relative border-l-2 border-border pl-6 sm:pl-8">
                <span class="absolute -left-[7px] top-1 h-3 w-3 rounded-full bg-primary-strong" aria-hidden="true" />
                <h3 class="font-heading text-lg font-bold text-brand">{formatMonth(month)}</h3>
                <ul class="mt-4 space-y-4">
                  {items.map((item) => (
                    <li class="rounded-lg border border-border bg-card p-5 shadow-soft">
                      <p class="font-heading font-bold">{item.title}</p>
                      <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">{item.blurb}</p>
                    </li>
                  ))}
                </ul>
              </section>
            ))
          }
        </div>
      </section>

      <!-- Now building -->
      <section aria-labelledby="building-title" class="mt-20">
        <h2 id="building-title" class="flex items-center gap-3 font-heading text-2xl font-bold">
          Now building
          <Badge status="in-progress" />
        </h2>
        <div class="mt-6 space-y-4">
          {
            inProgress.map((item) => (
              <Card class="border-l-4 !border-l-[var(--badge-progress-fg)]">
                <p class="font-heading font-bold">{item.title}</p>
                <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">{item.blurb}</p>
              </Card>
            ))
          }
        </div>
      </section>

      <!-- Up next -->
      <section aria-labelledby="next-title" class="mt-20">
        <h2 id="next-title" class="flex items-center gap-3 font-heading text-2xl font-bold">
          Up next
          <Badge status="planned" />
        </h2>
        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {
            planned.map((item) => (
              <Card>
                <p class="font-heading font-bold">{item.title}</p>
                <p class="mt-1.5 text-sm leading-relaxed text-muted-foreground">{item.blurb}</p>
              </Card>
            ))
          }
        </div>
      </section>

      <!-- The bigger vision -->
      <section aria-labelledby="vision-title" class="mt-20">
        <h2 id="vision-title" class="font-heading text-2xl font-bold">The bigger vision</h2>
        <p class="mt-3 max-w-2xl text-muted-foreground">
          Further out, clearly labeled — none of this is live yet, and we'd rather show you the direction than pretend.
        </p>

        <div class="mt-8">
          <AiVisionCard />
        </div>

        <div class="mt-6 grid gap-4 sm:grid-cols-2">
          {
            visionCards.map((item) => (
              <Card class="flex flex-col gap-2">
                <div class="flex items-start justify-between gap-3">
                  <p class="font-heading font-bold">{item.title}</p>
                  <Badge status="vision" class="mt-0.5" />
                </div>
                <p class="text-sm leading-relaxed text-muted-foreground">{item.blurb}</p>
              </Card>
            ))
          }
        </div>
      </section>

      <p class="mt-16 text-sm text-muted-foreground">
        Want to steer this list? <a href="/contact" class="font-medium text-brand hover:underline">Tell us what you need</a>
        — beta feedback genuinely changes the order.
      </p>
    </div>
  </div>

  <CtaBand />
</BaseLayout>

---
interface Props {
  class: string;
  id?: string;
  isLink?: boolean;
  href?: string;
}

const { class: buttonClass, id = "", isLink = false, href = "" } = Astro.props;
---

<!-- HTML -->{
  !isLink && (
    <div id={id}>
      <button class={buttonClass}>
        <slot />
      </button>
    </div>
  )
}

{
  isLink && (
    <div id={id}>
      <a class={buttonClass} href={href}>
        <slot />
      </a>
    </div>
  )
}

<!-- Styles -->
<style lang="scss">
  button,
  a {
    position: relative;
    border: 2px solid;
    border-radius: 12px;
    padding: 10px;
    overflow: hidden;
    text-decoration: none;
    display: inline-block;

    &:hover {
      opacity: 0.7;
    }

    &.shiny:before {
      position: absolute;
      content: "";
      height: 90px;
      width: 200px;
      background-image: -webkit-linear-gradient(left, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.2) 50%, transparent 50%);
      bottom: 0%;
      transform: skew(-45deg);
      left: -240px;
      animation: shiny-move 5s linear infinite;
    }

    @keyframes shiny-move {
      0% {
        left: -240px;
      }
      20% {
        left: 200px;
      }
      100% {
        left: 200px;
      }
    }
  }
</style>

<!-- Javascript -->
<script></script>

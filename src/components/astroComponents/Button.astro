---
interface props {
  class: string;
}

const { class: buttonClass } = Astro.props as props;
---

<!-- HTML -->
<div>
  <button class={buttonClass}><slot /></button>
</div>

<!-- Styles -->
<style lang="scss">
  button {
    position: relative;
    border: 2px solid;
    border-radius: 12px;
    padding: 10px;
    overflow: hidden;

    &:hover {
      opacity: 0.7;
    }

    &.shiny:before {
      position: absolute;
      content: "";
      height: 90px;
      width: 200px;
      background-image: -webkit-linear-gradient(
        left,
        rgba(255, 255, 255, 0) 0%,
        rgba(255, 255, 255, 0.2) 50%,
        transparent 50%
      );
      bottom: 0%;
      transform: skew(-45deg);
      left: -240px;
      animation: shiny-move 5s linear infinite;
    }

    @keyframes shiny-move {
      0% {
        left: -240px;
      }
      20% {
        left: 200px;
      }
      100% {
        left: 200px;
      }
    }
  }
</style>

<!-- Javascript -->
<script></script>

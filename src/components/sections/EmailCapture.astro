---
/**
 * Email-list capture — posts to the existing /api/email endpoint
 * (Google-Sheets backed). Progressive enhancement: without JS it's a normal
 * form POST; with JS it submits via fetch and announces the result.
 */
interface Props {
  /** Compact = single-row layout for CTA bands. */
  compact?: boolean;
  class?: string;
}
const { compact = false, class: className = "" } = Astro.props;
---

<form method="POST" action="/api/email" data-email-form class:list={["w-full", compact ? "max-w-xl" : "max-w-md", className]}>
  <div class:list={["flex flex-col gap-3", compact && "sm:flex-row"]}>
    <label class:list={["flex-1", !compact && "block"]}>
      <span class:list={[compact ? "sr-only" : "mb-1.5 block text-sm font-medium"]}>Name</span>
      <input
        type="text"
        name="name"
        required
        autocomplete="name"
        placeholder="Your name"
        class="min-h-11 w-full rounded-md border border-input bg-card px-3.5 text-base text-foreground placeholder:text-muted-foreground"
      />
    </label>
    <label class:list={["flex-1", !compact && "block"]}>
      <span class:list={[compact ? "sr-only" : "mb-1.5 block text-sm font-medium"]}>Email</span>
      <input
        type="email"
        name="email"
        required
        autocomplete="email"
        placeholder="you@business.ca"
        class="min-h-11 w-full rounded-md border border-input bg-card px-3.5 text-base text-foreground placeholder:text-muted-foreground"
      />
    </label>
    <button
      type="submit"
      class="min-h-11 shrink-0 rounded-md bg-primary-strong px-5 text-sm font-medium text-primary-foreground shadow-soft transition-all hover:shadow-lifted hover:brightness-110"
    >
      Get updates
    </button>
  </div>
  <p data-email-status aria-live="polite" class="mt-2 min-h-5 text-sm text-muted-foreground"></p>
</form>

<script>
  document.querySelectorAll<HTMLFormElement>("[data-email-form]").forEach((form) => {
    const status = form.querySelector<HTMLElement>("[data-email-status]")!;
    const button = form.querySelector<HTMLButtonElement>("button[type=submit]")!;

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      button.disabled = true;
      status.textContent = "Sending…";
      try {
        const res = await fetch(form.action, {
          method: "POST",
          body: new FormData(form),
        });
        if (!res.ok) throw new Error(String(res.status));
        status.textContent = "Thanks — you're on the list!";
        form.reset();
      } catch {
        status.textContent = "Something went wrong — please try again or email support@stocklore.app.";
      } finally {
        button.disabled = false;
      }
    });
  });
</script>

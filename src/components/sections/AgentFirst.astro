---
/**
 * The agent-first announcement — Stocklore's stated direction, advertised
 * prominently and badged honestly (In development; nothing here is live yet).
 */
import Badge from "../ui/Badge.astro";
import ChatMock from "./ChatMock.astro";

const PRINCIPLES = [
  {
    title: "You approve everything",
    copy: "Nothing executes on its own. The assistant drafts invoices, orders, and emails — you review the exact result and approve it before anything happens.",
  },
  {
    title: "Your permissions, enforced",
    copy: "It acts as you, bounded by your role — admin, edit, or view. The server stays the authority; the assistant never gets a back door.",
  },
  {
    title: "Any model, minimal cost",
    copy: "Provider-agnostic by design: AI providers are swappable by configuration, with usage metered per organization so costs stay predictable.",
  },
];
---

<section id="assistant" class="safe-x relative scroll-mt-20 overflow-hidden border-y border-border py-16 lg:py-24">
  <div class="sl-aurora" aria-hidden="true"></div>
  <div class="sl-grain" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto w-full max-w-6xl">
    <div class="mx-auto max-w-2xl text-center">
      <div class="flex items-center justify-center gap-3">
        <p class="text-xs font-semibold uppercase tracking-widest text-brand">The next chapter</p>
        <Badge status="vision" />
      </div>
      <h2 class="mt-3 font-heading text-3xl font-bold tracking-tight sm:text-4xl">
        Stocklore is becoming an <span class="sl-scan-mark">agent-first</span> platform
      </h2>
      <p class="mt-4 text-lg text-muted-foreground">
        In development and shipping in phases: an assistant that runs your back office from plain language — with you approving every action before it happens.
      </p>
    </div>

    <div class="mt-12 grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div class="rounded-lg border border-primary/40 bg-card p-6 shadow-lifted sm:p-8">
        <ChatMock />
        <p class="mt-5 text-xs text-muted-foreground">Illustrative — the assistant is in development, not live yet.</p>
      </div>

      <div>
        <ul class="space-y-5">
          {
            PRINCIPLES.map(({ title, copy }) => (
              <li class="flex gap-4">
                <span class="mt-1 flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-lightest text-brand dark:text-secondary" aria-hidden="true">
                  <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 6L9 17l-5-5" />
                  </svg>
                </span>
                <div>
                  <h3 class="font-heading font-bold">{title}</h3>
                  <p class="mt-1 text-sm leading-relaxed text-muted-foreground">{copy}</p>
                </div>
              </li>
            ))
          }
        </ul>

        <p class="mt-7 rounded-md border border-border bg-card px-4 py-3 text-sm text-muted-foreground">
          <strong class="text-foreground">Shipping in phases:</strong> answers about your own data → drafted documents with approval → outbound email → more channels.
        </p>

        <a href="/roadmap#assistant" class="mt-6 inline-flex min-h-11 items-center gap-1 font-medium text-brand hover:underline">
          Follow progress on the roadmap <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</section>

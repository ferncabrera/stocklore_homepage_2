---
/** Interior-page header: kicker + display title + lede on the aurora wash. */
interface Props {
  kicker?: string;
  title: string;
  lede?: string;
}
const { kicker, title, lede } = Astro.props;
---

<section class="safe-x relative overflow-hidden border-b border-border">
  <div class="sl-aurora" aria-hidden="true"></div>
  <div class="relative z-10 mx-auto w-full max-w-6xl py-14 sm:py-20">
    {kicker && <p class="sl-animate-in text-xs font-semibold uppercase tracking-widest text-brand">{kicker}</p>}
    <h1 class="sl-animate-in mt-2 max-w-3xl font-heading text-4xl font-bold tracking-tight sm:text-5xl" style="animation-delay: 60ms">
      {title}
    </h1>
    {
      lede && (
        <p class="sl-animate-in mt-5 max-w-2xl text-lg text-muted-foreground" style="animation-delay: 140ms">
          {lede}
        </p>
      )
    }
  </div>
</section>

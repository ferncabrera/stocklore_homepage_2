---
import { SITE } from "../../data/site";
import EmailCapture from "./EmailCapture.astro";
---

<section class="safe-x pb-20 pt-4 lg:pb-28">
  <div
    class="relative mx-auto w-full max-w-6xl overflow-hidden rounded-xl border border-primary/40 bg-lightest/50 px-6 py-12 text-center shadow-soft sm:px-12 dark:bg-lightest/15"
  >
    <div class="sl-aurora" aria-hidden="true"></div>
    <div class="sl-grain" aria-hidden="true"></div>
    <div class="relative z-10">
      <h2 class="font-heading text-3xl font-bold tracking-tight sm:text-4xl">Start running your inventory on Stocklore</h2>
      <p class="mx-auto mt-4 max-w-xl text-muted-foreground">
        Free during open beta. Seed a demo company or import your own data — either way, you'll be working within the hour.
      </p>
      <div class="mt-8 flex justify-center">
        <a
          href={SITE.portalUrl}
          class="inline-flex min-h-12 items-center justify-center rounded-md bg-primary-strong px-8 text-base font-medium text-primary-foreground shadow-soft transition-all hover:shadow-lifted hover:brightness-110"
        >
          Get started — it's free
        </a>
      </div>

      <div class="mx-auto mt-10 max-w-xl border-t border-border pt-8">
        <p class="mb-3 text-sm font-medium">Not ready yet? Get updates as we ship:</p>
        <div class="flex justify-center">
          <EmailCapture compact />
        </div>
      </div>
    </div>
  </div>
</section>

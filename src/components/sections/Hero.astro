---
import { SITE } from "../../data/site";
import Button from "../ui/Button.astro";
import BrowserFrame from "../ui/BrowserFrame.astro";
import CanadianFlag from "../layout/CanadianFlag.astro";

const MOCK_ROWS = [
  { name: "Garden Bench", sku: "GB-100", qty: "24", status: "In stock", tone: "live" },
  { name: "Oak Slats (1m)", sku: "OAK-1M", qty: "310", status: "In stock", tone: "live" },
  { name: "Steel Legs", sku: "STL-LEG", qty: "8", status: "Low stock", tone: "progress" },
  { name: "Assembly Service", sku: "SVC-ASM", qty: "—", status: "Service", tone: "muted" },
];
---

<section class="safe-x relative overflow-hidden">
  <div class="sl-aurora" aria-hidden="true"></div>
  <div class="sl-grain" aria-hidden="true"></div>

  <div class="relative z-10 mx-auto grid w-full max-w-6xl items-center gap-12 py-16 sm:py-20 lg:grid-cols-2 lg:gap-16 lg:py-28">
    <div class="max-w-xl">
      <h1 class="sl-animate-in font-heading text-4xl font-bold tracking-tight sm:text-5xl lg:text-[3.4rem] lg:leading-[1.05]">
        Inventory &amp; manufacturing software that punches
        <span class="sl-scan-mark">above its price</span>
      </h1>
      <p class="sl-animate-in mt-6 text-lg text-muted-foreground sm:text-xl" style="animation-delay: 90ms">
        Stocklore gives Canadian small businesses real inventory control, multi-level manufacturing, invoicing, and CRA-ready tax — without enterprise pricing
        or a six-week implementation.
      </p>
      <div class="sl-animate-in mt-8 flex flex-col gap-3 sm:flex-row sm:items-center" style="animation-delay: 180ms">
        <Button href={SITE.portalUrl} size="lg">Get started — it's free</Button>
        <Button href="#tour" variant="outline" size="lg">See what it does</Button>
      </div>
      <p class="sl-animate-in mt-6 flex flex-wrap items-center gap-x-2 gap-y-1 text-sm text-muted-foreground" style="animation-delay: 260ms">
        Free during open beta · No credit card ·
        <span class="inline-flex items-center gap-1.5">
          Canadian-owned <CanadianFlag class="h-3 w-auto" />
        </span>
      </p>
    </div>

    <div class="sl-animate-in relative" style="animation-delay: 200ms">
      <BrowserFrame label="Preview of the Stocklore app: a products list showing on-hand stock levels with a low-stock alert for Steel Legs.">
        <div class="p-4">
          <div class="flex items-center justify-between gap-2 pb-3">
            <span class="font-heading text-sm font-semibold">Products</span>
            <span class="rounded-md bg-primary-strong px-2.5 py-1 text-[11px] font-medium text-primary-foreground"> + New product </span>
          </div>
          <div class="grid grid-cols-[1fr_auto_auto] gap-x-4 gap-y-0 overflow-hidden rounded-md border border-border text-xs">
            <div class="contents text-[11px] font-semibold uppercase tracking-wide text-foreground/70">
              <span class="border-b border-border bg-muted px-3 py-2">Product</span>
              <span class="border-b border-border bg-muted px-3 py-2 text-right">On hand</span>
              <span class="border-b border-border bg-muted px-3 py-2">Status</span>
            </div>
            {
              MOCK_ROWS.map((row) => (
                <div class="contents">
                  <span class="truncate border-b border-border px-3 py-2.5 last:border-0">
                    <span class="font-medium">{row.name}</span>
                    <span class="ml-1.5 hidden text-muted-foreground sm:inline">{row.sku}</span>
                  </span>
                  <span class="border-b border-border px-3 py-2.5 text-right tabular-nums">{row.qty}</span>
                  <span class="border-b border-border px-3 py-2.5">
                    <span
                      class="inline-block rounded-sm px-1.5 py-0.5 text-[10px] font-semibold"
                      style={
                        row.tone === "live"
                          ? "background: var(--badge-live-bg); color: var(--badge-live-fg);"
                          : row.tone === "progress"
                            ? "background: var(--badge-progress-bg); color: var(--badge-progress-fg);"
                            : "background: var(--badge-vision-bg); color: var(--badge-vision-fg);"
                      }
                    >
                      {row.status}
                    </span>
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </BrowserFrame>

      <div class="absolute -bottom-5 right-2 hidden w-56 rounded-lg border border-border bg-card p-3 shadow-lifted sm:block" aria-hidden="true">
        <p class="flex items-center gap-2 text-xs font-semibold">
          <span class="inline-block h-2 w-2 rounded-full" style="background: var(--badge-progress-fg);"></span>
          Low stock alert
        </p>
        <p class="mt-1 text-[11px] leading-snug text-muted-foreground">
          Steel Legs fell below its reorder point (8 of 10). Time to order from Maple Supply Co.
        </p>
      </div>
    </div>
  </div>
</section>

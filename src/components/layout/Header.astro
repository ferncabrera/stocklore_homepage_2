---
import { SITE } from "../../data/site";
import Logo from "./Logo.astro";
import ThemeToggle from "./ThemeToggle.astro";
import Button from "../ui/Button.astro";

const NAV = [
  { href: "/features", label: "Features" },
  { href: "/#assistant", label: "AI Assistant", soon: true },
  { href: "/roadmap", label: "Roadmap" },
  { href: "/about", label: "About" },
  { href: "/contact", label: "Contact" },
];

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) => path === href;
---

<header class="safe-x sticky top-0 z-50 border-b border-border bg-background/85 backdrop-blur-md">
  <div class="mx-auto flex h-16 w-full max-w-6xl items-center justify-between gap-4">
    <Logo />

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Main">
      {
        NAV.map(({ href, label, soon }) => (
          <a
            href={href}
            aria-current={isActive(href) ? "page" : undefined}
            class:list={[
              "inline-flex min-h-11 items-center gap-1.5 rounded-md px-3 text-sm font-medium transition-colors",
              isActive(href) ? "text-foreground" : "text-muted-foreground hover:bg-muted hover:text-foreground",
            ]}
          >
            {label}
            {soon && (
              <span
                class="rounded-sm px-1 py-px text-[9px] font-semibold uppercase tracking-wide"
                style="background: var(--badge-vision-bg); color: var(--badge-vision-fg);"
              >
                Soon
              </span>
            )}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <ThemeToggle />
      <a
        href={SITE.portalUrl}
        class="hidden min-h-11 items-center rounded-md px-3 text-sm font-medium text-muted-foreground transition-colors hover:bg-muted hover:text-foreground sm:inline-flex"
      >
        Sign in
      </a>
      <div class="hidden sm:block">
        <Button href={SITE.portalUrl} size="sm">Get started</Button>
      </div>

      <button
        type="button"
        data-menu-toggle
        class="inline-flex h-11 w-11 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-muted hover:text-foreground lg:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open menu"
      >
        <svg data-icon-open class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
        <svg
          data-icon-close
          class="hidden h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M6 6l12 12M18 6L6 18"></path>
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" hidden class="border-t border-border lg:hidden">
    <nav class="mx-auto flex w-full max-w-6xl flex-col gap-1 py-3" aria-label="Mobile">
      {
        NAV.map(({ href, label, soon }) => (
          <a
            href={href}
            aria-current={isActive(href) ? "page" : undefined}
            class="flex min-h-11 items-center gap-1.5 rounded-md px-3 text-base font-medium text-foreground hover:bg-muted"
          >
            {label}
            {soon && (
              <span
                class="rounded-sm px-1 py-px text-[9px] font-semibold uppercase tracking-wide"
                style="background: var(--badge-vision-bg); color: var(--badge-vision-fg);"
              >
                Soon
              </span>
            )}
          </a>
        ))
      }
      <div class="mt-2 flex flex-col gap-2 border-t border-border pt-3">
        <a href={SITE.portalUrl} class="flex min-h-11 items-center rounded-md px-3 text-base font-medium text-muted-foreground hover:bg-muted"> Sign in </a>
        <Button href={SITE.portalUrl} class="mx-3">Get started — it's free</Button>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const menu = document.getElementById("mobile-menu");

  if (toggle && menu) {
    const setOpen = (open: boolean) => {
      menu.hidden = !open;
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      toggle.querySelector("[data-icon-open]")?.classList.toggle("hidden", open);
      toggle.querySelector("[data-icon-close]")?.classList.toggle("hidden", !open);
    };

    toggle.addEventListener("click", () => setOpen(menu.hidden));
    menu.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("a")) setOpen(false);
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !menu.hidden) {
        setOpen(false);
        toggle.focus();
      }
    });
  }
</script>

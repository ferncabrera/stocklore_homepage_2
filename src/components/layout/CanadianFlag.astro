---
/** Compact Canadian flag mark. Decorative — pair it with visible text. */
interface Props {
  class?: string;
}
const { class: className = "h-3.5 w-auto" } = Astro.props;
---

<svg viewBox="0 0 40 20" class={className} aria-hidden="true">
  <rect width="40" height="20" fill="#fff" rx="2"></rect>
  <rect width="10" height="20" fill="#d52b1e" rx="2"></rect>
  <rect x="30" width="10" height="20" fill="#d52b1e" rx="2"></rect>
  <path
    fill="#d52b1e"
    d="M20 3.2l1 2.3 2-.9-.6 2.4 2.3-.2-1.6 1.9 2.2 1.2-2.2.9.7 2.3-2.3-.7-.2 2.4-1.3-1.8-1.3 1.8-.2-2.4-2.3.7.7-2.3-2.2-.9 2.2-1.2-1.6-1.9 2.3.2-.6-2.4 2 .9z"
  ></path>
</svg>

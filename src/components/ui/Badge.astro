---
export type BadgeStatus = "live" | "in-progress" | "planned" | "vision";

interface Props {
  status: BadgeStatus;
  class?: string;
}

const { status, class: className = "" } = Astro.props;

/* Labels are always text — never color-only meaning. */
const LABELS: Record<BadgeStatus, string> = {
  live: "Live",
  "in-progress": "In progress",
  planned: "Planned",
  vision: "In development",
};

const STYLES: Record<BadgeStatus, string> = {
  live: "background: var(--badge-live-bg); color: var(--badge-live-fg);",
  "in-progress": "background: var(--badge-progress-bg); color: var(--badge-progress-fg);",
  planned: "background: var(--badge-planned-bg); color: var(--badge-planned-fg);",
  vision: "background: var(--badge-vision-bg); color: var(--badge-vision-fg);",
};
---

<span class:list={["inline-flex items-center rounded-sm px-2 py-0.5 text-xs font-semibold whitespace-nowrap", className]} style={STYLES[status]}>
  {LABELS[status]}
</span>

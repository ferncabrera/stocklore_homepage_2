---
interface Props {
  class?: string;
  /** Lifts on hover — for cards that are (or contain) links. */
  interactive?: boolean;
}
const { class: className = "", interactive = false } = Astro.props;
---

<div class:list={["rounded-lg border border-border bg-card p-6 shadow-soft", interactive && "transition-shadow hover:shadow-lifted", className]}>
  <slot />
</div>

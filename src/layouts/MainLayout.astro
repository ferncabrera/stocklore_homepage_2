---
import "@fontsource/roboto";

import Navbar from "../components/astroComponents/Navbar.astro";
import Footer from "../components/astroComponents/Footer.astro";
import stockloreLogo from "../assets/svg/SL.svg";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href={stockloreLogo.src}>
    <title>Stocklore</title>
  </head>
  <body id="special" class="bg-stone-700 font-roboto">
    <header>
      <Navbar />
    </header>
    <main>
      <slot></slot>
    </main>
    <footer>
      <Footer />
    </footer>
  </body>
</html>

<style>
  body {
    min-height: 100vh;
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  header {
    min-height: 50px;
  }
  footer {
    min-height: 50px;
  }
  main {
    flex: 1;
  }
</style>

<script></script>

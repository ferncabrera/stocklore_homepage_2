---
import "@fontsource-variable/rubik";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

import BaseHead from "../components/seo/BaseHead.astro";
import AnnouncementBar from "../components/layout/AnnouncementBar.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  jsonLd?: object[];
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead {...Astro.props} />
  </head>
  <body class="flex min-h-dvh flex-col bg-background font-sans text-foreground">
    <a
      href="#main"
      class="sr-only rounded-md bg-primary-strong px-4 py-3 text-primary-foreground focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100]"
    >
      Skip to content
    </a>
    <AnnouncementBar />
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />

    <script>
      // Gentle scroll reveals: gate on html.js-reveal so content is never
      // hidden without JS; the first section shows immediately (the hero has
      // its own load stagger).
      document.documentElement.classList.add("js-reveal");
      const io = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              io.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.1, rootMargin: "0px 0px -8% 0px" },
      );
      document.querySelectorAll("main section").forEach((section, i) => {
        section.classList.add("sl-reveal");
        if (i === 0) section.classList.add("is-visible");
        else io.observe(section);
      });
    </script>
  </body>
</html>

---
import "@fontsource-variable/rubik";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

import BaseHead from "../components/seo/BaseHead.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  jsonLd?: object[];
}
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead {...Astro.props} />
    <script is:inline>
      // Theme FOUC guard — must run before first paint.
      (() => {
        try {
          const stored = localStorage.getItem("theme");
          const dark = stored ? stored === "dark" : window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.classList.toggle("dark", dark);
        } catch {
          /* no-op: default to light */
        }
      })();
    </script>
  </head>
  <body class="flex min-h-dvh flex-col bg-background font-sans text-foreground">
    <a
      href="#main"
      class="sr-only rounded-md bg-primary-strong px-4 py-3 text-primary-foreground focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100]"
    >
      Skip to content
    </a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
